<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/layout_toolbar"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.maplibre.android.maps.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:id="@+id/mapInfoPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@color/primaryColor"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/mapInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/openstreetmap_pick_help"
                android:textColor="@color/secondaryTextColor"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/mapCoordinates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/primaryTextColor"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/mapAttribution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/openstreetmap_attribution"
                android:textColor="@color/secondaryTextColor"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/useMapLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:onClick="onUseLocationClick"
                android:text="@string/use_this_location"
                android:visibility="gone"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
